# Скопируйте в .env и подставьте свои значения. Файл .env не коммитится.

# PostgreSQL
# Для npm run dev (без Docker): хост localhost
DATABASE_URL=postgresql://materiamedica:YOUR_PASSWORD@localhost:5432/materiamedica
# Для docker-compose.dev: задаётся POSTGRES_PASSWORD; приложение в контейнере получит URL с хостом db автоматически.
# Если пароль содержит @ : / $ % и т.п., укажите полный URL с закодированным паролем:
# DATABASE_URL_DOCKER=postgresql://materiamedica:encoded_password@db:5432/materiamedica
POSTGRES_PASSWORD=your_postgres_password

# Node.js
SESSION_SECRET=your_session_secret_min_32_chars

# Redis (optional; for WebSocket pub/sub and recent messages cache). If not set, health wall works without real-time and cache.
# REDIS_URL=redis://localhost:6379

# Yandex Cloud S3
YC_BUCKET=your_bucket
YC_REGION=ru-central1
YC_ACCESS_KEY_ID=
YC_SECRET_ACCESS_KEY=

# Robokassa
ROBOKASSA_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=

# Для docker-compose.dev: COOKIE_SECURE=false задаётся в compose. Для прода — .env.prod с COOKIE_SECURE=true
# APP_URL=https://your-domain.ru
